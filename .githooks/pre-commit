#!/usr/bin/env bash
# Secret-scanning pre-commit hook (gitleaks).
# Blocks commits that introduce secrets into staged changes.
# Bypass (use sparingly, and only when you are certain): git commit --no-verify

if ! command -v gitleaks >/dev/null 2>&1; then
	echo "warning: gitleaks not found on PATH; skipping secret scan." >&2
	echo "         install: https://github.com/gitleaks/gitleaks/releases (drop the binary in ~/.local/bin)" >&2
	exit 0
fi

if ! gitleaks git --staged --no-banner --redact; then
	echo >&2
	echo "gitleaks: a potential secret was detected in your staged changes; commit blocked." >&2
	echo "review the finding above. if it is a genuine false positive, allowlist it in .gitleaks.toml," >&2
	echo "or bypass with: git commit --no-verify" >&2
	exit 1
fi

exit 0
