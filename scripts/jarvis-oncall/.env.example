# Jarvis On-Call bot — environment
# Install to /opt/jarvis-oncall/.env (chmod 600). Never commit the real token.

# Discord bot token — pull from Vaultwarden and paste here.
DISCORD_TOKEN=

# Your Discord user ID (the allowlist-of-one). Enable Developer Mode in Discord,
# right-click your name -> Copy User ID. The bot answers ONLY this user.
ALLOWED_USER_ID=

# Channel the bot listens in. 0 = respond in DMs with the allowed user only.
# Set to a channel ID to also answer in that one channel.
CHANNEL_ID=0

# llm_router endpoint (Jarvis local). Model default is the local 72B; set
# ROUTER_MODEL=claude-opus-4-8 for the most reliable tool-calling (needs the
# router's ANTHROPIC_API_KEY to be set).
ROUTER_URL=http://127.0.0.1:8000
ROUTER_MODEL=qwen2.5:72b

# Audit log location (dir is created if missing).
ONCALL_LOG_DIR=/var/log/jarvis-oncall
