# /etc/llm_router.env — environment for the llm_router systemd service.
# Copy to /etc/llm_router.env on Jarvis (chmod 600) and fill in.

# Local Ollama backend (default route)
OLLAMA_URL=http://127.0.0.1:11434
LOCAL_MODEL=qwen2.5:72b

# Claude escalation/fallback (optional — leave ANTHROPIC_API_KEY unset for local-only)
# ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-8

# Listener
LLM_ROUTER_HOST=0.0.0.0
LLM_ROUTER_PORT=8000
LLM_ROUTER_MAX_TOKENS=16000
